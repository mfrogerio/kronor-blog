---
import { getBlogPost } from '../../lib/contentful';
import { documentToHtmlString } from '@contentful/rich-text-html-renderer';

const { slug } = Astro.params;
const post = await getBlogPost(slug as string);

if (!post) {
  return Astro.redirect('/404');
}

const bodyHtml = post.content ? documentToHtmlString(post.content) : '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.title} — Kronor & Beyond</title>
    <meta name="description" content={post.quickAnswer} />
  </head>
  <body>
    <a href="/blog">← Back to all posts</a>

    <h1>{post.title}</h1>

    {post.quickAnswer && (
      <p><strong>Quick answer:</strong> {post.quickAnswer}</p>
    )}

    <article set:html={bodyHtml} />

    {post.featuredAffiliate && post.subId && (
      <p>
        <a href={`/go/${post.featuredAffiliate.toLowerCase()}?subid=${post.subId}`}>
          Check {post.featuredAffiliate} →
        </a>
      </p>
    )}
  </body>
</html>