---
import { getBlogPost } from '../../lib/contentful';

export const prerender = false;

const { slug } = Astro.params;

let post;
let error;

try {
  post = await getBlogPost(slug as string);
  if (!post) {
    return Astro.redirect('/404');
  }
} catch (e) {
  error = e;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post?.title || 'Post'} — Kronor & Beyond</title>
  </head>
  <body>
    <a href="/blog">← Back to all posts</a>

    {error && (
      <div style="color: red;">
        <h2>Error loading post</h2>
        <p>{String(error)}</p>
      </div>
    )}

    {post && (
      <>
        <h1>{post.title}</h1>

        {post.quickAnswer && (
          <p><strong>Quick answer:</strong> {post.quickAnswer}</p>
        )}

        <div>
          <p>[Post content - Rich text rendering coming soon]</p>
        </div>

        {post.featuredAffiliate && post.subId && (
          <p>
            <a href={`/go/${post.featuredAffiliate.toLowerCase()}?subid=${post.subId}`}>
              Check {post.featuredAffiliate} →
            </a>
          </p>
        )}
      </>
    )}
  </body>
</html>